# Rotas conhecidas da SPA. O destino deve ser a raiz: no Cloudflare Pages,
# /index.html e canonicalizado para / e quebra o rewrite. Nao use fallback
# global: um JS inexistente precisa responder 404, nunca o shell com status 200.
/a                   /   200
/login               /   200
/cadastro            /   200
/recuperar-senha     /   200
/mfa                 /   200
/onboarding          /   200
/dashboard           /   200
/avaliados           /   200
/configuracoes       /   200
/auditoria           /   200
/agenda               /   200
/carteira            /   200
/exercicios          /   200

# O Pages exige redirects estaticos antes dos dinamicos.
/a/*                 /   200
/avaliados/*         /   200
/ferramentas/*       /   200

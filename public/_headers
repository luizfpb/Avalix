# O Pages já gerencia e invalida os assets com hash a cada deploy. Não force
# cache imutável: um fallback HTML nunca pode ficar preso sob uma URL de JS.

/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Cloudflare-CDN-Cache-Control: no-store

/sw.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Cloudflare-CDN-Cache-Control: no-store

/registerSW.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Cloudflare-CDN-Cache-Control: no-store

/manifest.webmanifest
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Cloudflare-CDN-Cache-Control: no-store

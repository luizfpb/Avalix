# HTML, manifest e service worker nunca ficam presos no cache. Somente arquivos
# em /assets têm hash no nome e podem ser imutáveis; _redirects não aplica
# fallback global a um JS inexistente.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000
  Referrer-Policy: no-referrer
  X-Robots-Tag: noindex, nofollow, noarchive
  Permissions-Policy: camera=(self), microphone=(), geolocation=(), payment=(), usb=(), clipboard-write=(self)
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.supabase.co; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://cdn.jsdelivr.net https://storage.googleapis.com; worker-src 'self' blob:; manifest-src 'self'; media-src 'self' blob:

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Cloudflare-CDN-Cache-Control: no-store


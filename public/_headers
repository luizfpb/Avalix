# Cabeçalhos do Cloudflare Pages para evitar cache "velho" depois de cada deploy.
# Os assets têm hash no nome (imutáveis) → cacheia forte. Já o index.html, o
# service worker e o manifest têm que ser sempre revalidados, senão o app fica
# apontando pra chunks que não existem mais (erro "Failed to fetch dynamically
# imported module").

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: no-cache

/sw.js
  Cache-Control: no-cache

/registerSW.js
  Cache-Control: no-cache

/manifest.webmanifest
  Cache-Control: no-cache
